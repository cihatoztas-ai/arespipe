{
  "outputDirectory": "mobile/dist",
  "buildCommand": "cd mobile && npm run build",
  "installCommand": "cd mobile && npm install",
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/mobile/:path*", "destination": "/index.html" },
    { "source": "/mobile", "destination": "/index.html" }
  ]
}
